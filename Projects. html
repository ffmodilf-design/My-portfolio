            background:#00ff88;
            color:#000;
            padding:16px 40px;
            border-radius:50px;
            text-decoration:none;
            font-weight:900;
            font-size:1.2em;
            display:inline-block;
            margin-top:20px;
            transition:0.3s;
            box-shadow:0 0 20px rgba(0,255,136,0.3);
        }
