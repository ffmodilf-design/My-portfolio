<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>أعمالي السابقة | Sohail Alaoui</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Cairo:wght@700;900&display=swap');
        *{margin:0; padding:0; box-sizing:border-box; font-family:'Cairo', sans-serif;}
        body{
            background:#0a0a0a; 
            color:#fff; 
            text-align:center; 
            padding:60px 20px;
            min-height:100vh;
        }
        .container{max-width:700px; margin:auto;}

        h1{
            font-size:2.8em; 
            color:#00ff88; 
            margin-bottom:50px; 
            font-weight:900;
            text-shadow:0 0 20px rgba(0,255,136,0.5);
        }
        
        .projects-grid{
            display:flex;
            flex-direction:column;
            gap:25px;
            margin-bottom:40px;
        }

        /* الكارت بحال الصورة */
        .project-card{
            background:#111;
            border:2px solid #00ff88;
            border-radius:18px;
            padding:30px 25px;
            transition:0.3s;
            cursor:pointer;
            text-decoration:none;
            display:block;
            box-shadow:0 0 15px rgba(0,255,136,0.1);
        }
        .project-card:hover{
            transform:scale(1.02);
            background:#151515;
            box-shadow:0 0 30px rgba(0,255,136,0.4);
            border-color:#00ff88;
        }
        .project-card h3{
            color:#00ff88; 
            font-size:1.6em; 
            margin-bottom:15px;
            font-weight:700;
        }
        .project-card p{
            color:#ccc; 
            font-size:1.05em;
            line-height:1.8;
        }

        /* زر الرجوع الاخضر الكبير */
